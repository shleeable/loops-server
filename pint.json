{
    "preset": "laravel",
    "rules": {
        "simplified_null_return": true,
        "not_operator_with_successor_space": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true,
        "fully_qualified_strict_types": false,
        "array_syntax": {
            "syntax": "short"
        }
    },
    "exclude": ["bootstrap/cache", "storage", "vendor"]
}
